-- LOOPBRING FUNCTION
local function startLoopBring()
	if loopBringConnection then return end

	loopBringConnection = RunService.Heartbeat:Connect(function()
		pcall(function()
			if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
				local root = player.Character.HumanoidRootPart

				for _, otherPlayer in pairs(Players:GetPlayers()) do
					if otherPlayer ~= player and otherPlayer.Character then
						local theirRoot = otherPlayer.Character:FindFirstChild("HumanoidRootPart")
						if theirRoot then
							theirRoot.CFrame = root.CFrame * CFrame.new(0, 0, -5)
						end
					end
				end
			end
		end)
	end)
	print("[Gabo] LoopBring started!")
end

local function stopLoopBring()
	if loopBringConnection then
		loopBringConnection:Disconnect()
		loopBringConnection = nil
		print("[Gabo] LoopBring stopped!")
	end
end

-- ESP FUNCTION
local function startESP()
	if espConnection then return end

	local Camera = workspace.CurrentCamera

	local function createESP(plr)
		if espData[plr] then return end

		local nameText = Drawing.new("Text")
		nameText.Size = 16
		nameText.Color = Color3.fromRGB(255, 255, 255)
		nameText.Center = true
		nameText.Outline = true
		nameText.Font = 2
		nameText.Visible = false

		local distText = Drawing.new("Text")
		distText.Size = 14
		distText.Color = Color3.fromRGB(100, 200, 255)
		distText.Center = true
		distText.Outline = true
		distText.Font = 2
		distText.Visible = false

		local healthText = Drawing.new("Text")
		healthText.Size = 14
		healthText.Color = Color3.fromRGB(0, 255, 0)
		healthText.Center = true
		healthText.Outline = true
		healthText.Font = 2
		healthText.Visible = false

		local box = Drawing.new("Square")
		box.Thickness = 2
		box.Color = Color3.fromRGB(255, 255, 255)
		box.Filled = false
		box.Visible = false

		espData[plr] = {
			Name = nameText,
			Distance = distText,
			Health = healthText,
			Box = box
		}
	end

	local function removeESP(plr)
		if espData[plr] then
			for _, obj in pairs(espData[plr]) do
				if obj.Remove then obj:Remove() end
			end
			espData[plr] = nil
		end
	end

	local function updateESP()
		for _, plr in pairs(Players:GetPlayers()) do
			if plr ~= player and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") and plr.Character:FindFirstChild("Head") then
				local hrp = plr.Character.HumanoidRootPart
				local head = plr.Character.Head
				local hum = plr.Character:FindFirstChildOfClass("Humanoid")

				if hum and hum.Health > 0 then
					createESP(plr)
					local data = espData[plr]

					local screenPos, onScreen = Camera:WorldToViewportPoint(head.Position)
					local rootPos = Camera:WorldToViewportPoint(hrp.Position)

					if onScreen then
						local dist = math.floor((Camera.CFrame.Position - hrp.Position).Magnitude)

						-- Name
						data.Name.Text = plr.Name
						data.Name.Position = Vector2.new(screenPos.X, screenPos.Y - 40)
						data.Name.Visible = true

						-- Distance
						data.Distance.Text = dist .. "m"
						data.Distance.Position = Vector2.new(screenPos.X, screenPos.Y - 20)
						data.Distance.Visible = true

						-- Health
						data.Health.Text = math.floor(hum.Health) .. " HP"
						data.Health.Position = Vector2.new(screenPos.X, screenPos.Y - 5)

						-- Health color
						local healthPercent = hum.Health / hum.MaxHealth
						if healthPercent > 0.5 then
							data.Health.Color = Color3.fromRGB(0, 255, 0)
						elseif healthPercent > 0.25 then
							data.Health.Color = Color3.fromRGB(255, 255, 0)
						else
							data.Health.Color = Color3.fromRGB(255, 0, 0)
						end
						data.Health.Visible = true

						-- Box
						local size = (Camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0)).Y - Camera:WorldToViewportPoint(hrp.Position + Vector3.new(0, 2.5, 0)).Y) / 2
						data.Box.Size = Vector2.new(size * 1.5, size * 2)
						data.Box.Position = Vector2.new(rootPos.X - size * 0.75, rootPos.Y - size)
						data.Box.Visible = true
					else
						data.Name.Visible = false
						data.Distance.Visible = false
						data.Health.Visible = false
						data.Box.Visible = false
					end
				else
					removeESP(plr)
				end
			else
				removeESP(plr)
			end
		end
	end

	Players.PlayerRemoving:Connect(removeESP)

	espConnection = RunService.RenderStepped:Connect(updateESP)
	print("[FROSTY] ESP started!")
end

local function stopESP()
	if espConnection then
		espConnection:Disconnect()
		espConnection = nil
	end

	for plr, data in pairs(espData) do
		for _, obj in pairs(data) do
			if obj.Remove then obj:Remove() end
		end
	end
	espData = {}
	print("[GABO] ESP stopped!")
end

-- FANTASMA PVP AIMBOT
local function startFantasma()
	if fantasmaConnection then return end

	local UIS = UserInputService
	local Camera = workspace.CurrentCamera
	local aiming = false
	local fovRadius = 150
	local smoothing = 5

	local function getClosestTarget()
		local closestDist = math.huge
		local targetPart = nil
		local mousePos = UIS:GetMouseLocation()

		for _, p in pairs(Players:GetPlayers()) do
			if p ~= player and p.Character and p.Character:FindFirstChild("Head") then
				local head = p.Character.Head
				local hum = p.Character:FindFirstChildOfClass("Humanoid")
				if hum and hum.Health > 0 then
					local screenPos, onScreen = Camera:WorldToViewportPoint(head.Position)
					if onScreen then
						local dist = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
						if dist < closestDist and dist <= fovRadius then
							closestDist = dist
							targetPart = head
						end
					end
				end
			end
		end
		return targetPart
	end

	local function moveMouseTowards(target)
		local screenPos = Camera:WorldToViewportPoint(target.Position)
		local mousePos = UIS:GetMouseLocation()
		local dx = (screenPos.X - mousePos.X) / smoothing
		local dy = (screenPos.Y - mousePos.Y) / smoothing
		mousemoverel(dx, dy)
	end

	UIS.InputBegan:Connect(function(input, gp)
		if not gp and input.UserInputType == Enum.UserInputType.MouseButton2 then
			aiming = true
		end
	end)

	UIS.InputEnded:Connect(function(input, gp)
		if not gp and input.UserInputType == Enum.UserInputType.MouseButton2 then
			aiming = false
		end
	end)

	fantasmaConnection = RunService.RenderStepped:Connect(function()
		if aiming then
			local target = getClosestTarget()
			if target then
				moveMouseTowards(target)
			end
		end
	end)

	print("[GABO] Fantasma PVP started!")
end

local function stopFantasma()
	if fantasmaConnection then
		fantasmaConnection:Disconnect()
		fantasmaConnection = nil
		print("[FROSTY] Fantasma PVP stopped!")
	end
end

