				introText.TextTransparency = 1
				introText.ZIndex = 11

				wait(0.5)
				local fadeIn = TweenService:Create(introText, TweenInfo.new(1), {TextTransparency = 0})
				fadeIn:Play()
				fadeIn.Completed:Wait()
				wait(2)
				local fadeOut = TweenService:Create(introText, TweenInfo.new(0.8), {TextTransparency = 1})
