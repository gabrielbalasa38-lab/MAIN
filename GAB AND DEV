	addScript("fantasma", "Fantasma PVP", "Custom aimbot with GUI controls", "Built-in", function(state)
		if state then
			pcall(function()
				local UIS = UserInputService
				local TweenService = game:GetService("TweenService")
				local Camera = workspace.CurrentCamera

				local aiming = false
				local fovRadius = 150
				local smoothing = 5
				local scriptEnabled = true

				-- Intro Screen
				local introGui = Instance.new("ScreenGui", game:GetService("CoreGui"))
				introGui.Name = "FantasmaIntro"
				introGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

				local blackScreen = Instance.new("Frame", introGui)
